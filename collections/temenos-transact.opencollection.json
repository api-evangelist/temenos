            ]
          },
          "docs": "Retrieve the list of supported countries with their ISO codes, names, and associated regulatory information."
        },
        {
          "info": {
            "name": "List IBAN Structures",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.temenos.com/transact/v1/reference/ibanStructures",
            "params": [
              {
                "name": "countryCode",
                "value": "",
                "type": "query",
                "description": "Filter by ISO 3166-1 alpha-2 country code"
              }
            ]
          },
          "docs": "Retrieve IBAN validation structures by country including the expected format, length, and check digit calculation rules."
        }
      ]
